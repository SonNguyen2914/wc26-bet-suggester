# --- Mode ---
DEMO_MODE=true

# --- Kalshi (only needed when DEMO_MODE=false) ---
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# --- Archive database (WC26 plane: SQLite default) ---
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/kalshi

# --- LIVE plane (MLS) — dormant when unset. Any postgres:// or
# postgresql:// scheme is normalized to postgresql+psycopg:// (psycopg 3).
# LIVE_DATABASE_URL=postgresql://user:pass@host:5432/live

# --- Operating modes (fail-safe parsed: unknown values pick the safer
# mode). Real-money and auto-execution have NO enabled code paths.
COMPETITION=mls-2026
MLS_SHADOW_ENABLED=true
REAL_MONEY_SIGNALS_ENABLED=false
AUTO_EXECUTION_ENABLED=false

# --- Engine ---
N_SIMULATIONS=10000
PREDICTION_CACHE_TTL_SECONDS=300
HOURLY_PREDICTION_WINDOW_HOURS=6
FINAL_LOCK_MINUTES=10

# --- Filters ---
MIN_EDGE=0.05
MIN_CONFIDENCE=0.45
MIN_VOLUME_24H=10000

# --- Alerts (Discord two-channel split + secret ntfy topic) ---
DISCORD_ACTION_WEBHOOK_URL=
DISCORD_DETAIL_WEBHOOK_URL=
NTFY_TOPIC=

# --- API ---
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,https://namson.dev

# --- Bet-timing (ripeness) alerts ---
ODDS_POLL_SECONDS=30
RIPENESS_ALERT_THRESHOLD=75
RIPENESS_MIN_READINGS=10
ALERT_COOLDOWN_MINUTES=30

# Post-tournament lockdown: fail-closed EVERYWHERE by default (V9 eval
# F9.9 — the example must not ship a value that reopens writes when copied
# to prod). Set PUBLIC_READ_ONLY=false explicitly for LOCAL DEV only.
PUBLIC_READ_ONLY=true
ADMIN_TOKEN=
