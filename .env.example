# --- Mode ---
DEMO_MODE=true

# --- Kalshi (only needed when DEMO_MODE=false) ---
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# --- Database (SQLite default; uncomment for Postgres) ---
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/kalshi

# --- Engine ---
N_SIMULATIONS=10000
PREDICTION_CACHE_TTL_SECONDS=300
HOURLY_PREDICTION_WINDOW_HOURS=6
FINAL_LOCK_MINUTES=10

# --- Filters ---
MIN_EDGE=0.05
MIN_CONFIDENCE=0.45
MIN_VOLUME_24H=10000

# --- Alerts ---
DISCORD_WEBHOOK_URL=

# --- API ---
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,https://namson.dev

# --- Bet-timing (ripeness) alerts ---
ODDS_POLL_SECONDS=30
RIPENESS_ALERT_THRESHOLD=75
RIPENESS_MIN_READINGS=10
ALERT_COOLDOWN_MINUTES=30

# Post-tournament lockdown: fail-closed in prod; dev opts out explicitly
PUBLIC_READ_ONLY=false
ADMIN_TOKEN=
